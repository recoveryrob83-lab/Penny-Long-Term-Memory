# Copy this file to .env and fill in local values.
# Never commit .env. The dashboard reads connected sources only.

# Trello Flow Board
TRELLO_API_KEY=
TRELLO_API_TOKEN=
TRELLO_BOARD_ID=

# Todoist personal API token
TODOIST_API_TOKEN=

# Google Calendar private Secret address in iCal format
GOOGLE_CALENDAR_ICAL_URL=

# Google Sheets cloud mirror for scheduled jobs
# The spreadsheet must contain a tab named Run Ledger with the approved columns.
GOOGLE_SHEETS_LEDGER_SPREADSHEET_ID=
# Bound Apps Script web-app deployment URL ending in /exec.
GOOGLE_SHEETS_LEDGER_WEB_APP_URL=
# Long random value matching the Apps Script LEDGER_SECRET Script Property.
GOOGLE_SHEETS_LEDGER_SHARED_SECRET=
# GOOGLE_SHEETS_LEDGER_SHEET_NAME=Run Ledger

# Shared local display timezone
LIFEOS_TIMEZONE=America/Chicago

# Guarded local GitHub synchronization
# Enabled by default. It only fast-forwards a clean main branch.
# LIFEOS_GITHUB_AUTO_SYNC=1
# LIFEOS_GITHUB_SYNC_BRANCH=main

# Optional overrides
# LIFEOS_REPOSITORY_ROOT=C:\Users\Rob\Documents\GitHub\Penny-Long-Term-Memory
# TRELLO_CACHE_PATH=.local\trello_flow_cache.json
# TODOIST_CACHE_PATH=.local\todoist_commitments_cache.json
# GOOGLE_CALENDAR_CACHE_PATH=.local\google_calendar_cache.json
# TRELLO_API_BASE_URL=https://api.trello.com/1
# TODOIST_API_BASE_URL=https://api.todoist.com/api/v1
# TODOIST_HORIZON_DAYS=7
# TODOIST_COMMITMENT_LIMIT=6
# CALENDAR_HORIZON_DAYS=14
