{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lifeos://schemas/worker-result-rejection/v1",
  "title": "LifeOS Worker Result Rejection v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "artifact_type",
    "attempt",
    "run_id",
    "worker_id",
    "rejected_report_path",
    "rejected_report_checksum",
    "validation_errors",
    "next_report_attempt",
    "work_reexecution_authorized",
    "scope_expansion_authorized",
    "escalation_required"
  ],
  "properties": {
    "schema_id": {"const": "lifeos_worker_result_rejection"},
    "schema_version": {"type": "integer", "const": 1},
    "artifact_type": {"const": "rejection"},
    "attempt": {"type": "integer", "minimum": 1},
    "run_id": {"type": "string", "minLength": 1},
    "worker_id": {"type": "string", "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"},
    "rejected_report_path": {"type": "string", "minLength": 1},
    "rejected_report_checksum": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "validation_errors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "field", "message", "expected", "observed_type", "observed_summary"],
        "properties": {
          "code": {"type": "string", "minLength": 1},
          "field": {"type": "string", "minLength": 1},
          "message": {"type": "string", "minLength": 1},
          "expected": {"type": "string", "minLength": 1},
          "observed_type": {"type": "string", "minLength": 1},
          "observed_summary": {"type": "string"}
        }
      }
    },
    "next_report_attempt": {"type": "integer", "minimum": 2},
    "work_reexecution_authorized": {"const": false},
    "scope_expansion_authorized": {"const": false},
    "escalation_required": {"type": "boolean"}
  }
}
