{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lifeos://schemas/worker-result-report/v1",
  "title": "LifeOS Worker Result Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "artifact_type",
    "attempt",
    "wrapper_id",
    "run_id",
    "worker_id",
    "profile_version",
    "owning_department",
    "task_id",
    "task_revision",
    "procedure_id",
    "procedure_version",
    "authorization_source",
    "verification_mode",
    "requested_action",
    "actual_action_attempted",
    "controlled_outcome",
    "completion_state",
    "evidence_references",
    "actual_read_scopes",
    "actual_write_scopes",
    "actual_tools",
    "what_did_not_occur",
    "unresolved_risks",
    "review_condition",
    "verification_state",
    "external_actions_verified",
    "approval_required_discovered",
    "failure_reason"
  ],
  "properties": {
    "schema_id": {"const": "lifeos_worker_result_report"},
    "schema_version": {"type": "integer", "const": 1},
    "artifact_type": {"const": "worker_report"},
    "attempt": {"type": "integer", "minimum": 1},
    "wrapper_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "worker_id": {"type": "string", "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"},
    "profile_version": {"type": "integer", "minimum": 1},
    "owning_department": {"type": "string", "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"},
    "task_id": {"type": "string", "minLength": 1},
    "task_revision": {"type": "integer", "minimum": 1},
    "procedure_id": {"type": "string", "minLength": 1},
    "procedure_version": {"type": "integer", "minimum": 1},
    "authorization_source": {"type": "string", "minLength": 1},
    "verification_mode": {"enum": ["AUTOMATIC", "ROUTINE_BATCH", "IMMEDIATE_HQ"]},
    "requested_action": {"type": "string", "minLength": 1},
    "actual_action_attempted": {"type": "string", "minLength": 1},
    "controlled_outcome": {"enum": ["IMPLEMENT", "REPORT_AND_HOLD", "ELEVATE_FOR_APPROVAL"]},
    "completion_state": {"enum": ["completed", "partial", "failed", "not_attempted"]},
    "evidence_references": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "actual_read_scopes": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "actual_write_scopes": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "actual_tools": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "what_did_not_occur": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "unresolved_risks": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "review_condition": {"type": "string", "minLength": 1},
    "verification_state": {"enum": ["pending", "unavailable"]},
    "external_actions_verified": {"type": "boolean"},
    "approval_required_discovered": {"type": "boolean"},
    "failure_reason": {"type": ["string", "null"]}
  }
}
